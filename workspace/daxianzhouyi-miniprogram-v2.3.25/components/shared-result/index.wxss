/* components/shared-result/index.wxss - 共享结果组件 */

.shared-result { width: 100%; }

/* ---- 卦象信息 ---- */
.hexagram-info {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 140rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  border: 1rpx solid #F0F0F0;
}

.hexagram-left { text-align: center; }
.hexagram-right { text-align: center; }

.hexagram-right .trigram-item:first-child {
  margin-bottom: 12rpx;
}

.number {
  font-size: 26rpx;
  color: #999999;
  display: block;
  margin-bottom: 8rpx;
}

.name {
  font-size: 52rpx;
  font-weight: 800;
  color: #C41E3A;
  display: inline;
  letter-spacing: 4rpx;
}

.symbol {
  font-size: 52rpx;
  color: #000000;
  margin-left: 8rpx;
  display: inline;
}


.line-name {
  font-size: 28rpx;
  color: #888888;
  display: block;
  margin-top: 6rpx;
}

.trigram-label {
  font-size: 24rpx;
  color: #BBBBBB;
  display: block;
  margin-bottom: 4rpx;
}

.trigram-value {
  font-size: 30rpx;
  color: #444444;
  display: block;
  font-weight: 600;
}

/* ---- 选项卡 ---- */
.tabs {
  display: flex;
  margin-bottom: 20rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 6rpx;
}

.tab {
  flex: 1;
  padding: 18rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
  background: transparent;
  font-weight: 500;
  border-radius: 10rpx;
  transition: all 0.2s ease;
}

.tab.active {
  background: #C41E3A;
  color: #FFFFFF;
  font-weight: 600;
}

/* ---- 详情列表 ---- */
.hexagram-detail { padding: 0; }

.detail-item {
  padding: 20rpx;
  margin-bottom: 12rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  border: 1rpx solid #F0F0F0;
}

.detail-item:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 24rpx;
  color: #999999;
  font-weight: 500;
}

.detail-value {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.7;
  display: block;
  margin-top: 8rpx;
}

.line-block {
  font-size: 30rpx;
  font-weight: 700;
  color: #C41E3A;
  display: block;
}

/* ---- 两列详解 ---- */
.detail-columns {
  display: flex;
  gap: 16rpx;
}

.detail-column {
  flex: 1;
  background: #FAFAFA;
  border-radius: 14rpx;
  padding: 20rpx;
  border: 1rpx solid #F0F0F0;
}

.column-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #C41E3A;
  display: block;
  margin-bottom: 14rpx;
  text-align: center;
}

/* ---- 解锁区域 ---- */
.share-blur {
  padding: 48rpx 32rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  border: 1rpx solid #F0F0F0;
  text-align: center;
}

.blur-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 10rpx;
}

.blur-hint {
  font-size: 22rpx;
  color: #999999;
  display: block;
  margin-bottom: 24rpx;
}

.share-btn {
  background: #C41E3A;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  padding: 20rpx 48rpx;
  border-radius: 10rpx;
  border: none;
}
.share-btn::after { border: none; }
