<view class="container">
  <!-- 版本号 -->
  <view class="header">
    <text class="version">{{version}}</text>
  </view>

  <!-- 摇卦提示 -->
  <view class="shake-hint-container" wx:if="{{showShakeHint && !isShaking && !isAnimating}}">
    <view class="shake-hint-card">
      <view class="shake-icon-wrapper"><text class="shake-icon">📳</text></view>
      <text class="shake-hint-title">摇动手机探索易经</text>
      <text class="shake-hint-desc">像摇骰子一样上下左右摇晃手机</text>
    </view>
  </view>

  <!-- 摇卦动画 -->
  <view class="shaking-area" wx:if="{{isShaking}}">
    <image class="shaking-img shake-animation" src="/assets/shaking.svg" mode="widthFix"></image>
    <text class="shaking-text active">探索中...</text>
  </view>
  <view class="shaking-area" wx:if="{{isAnimating && !isShaking}}">
    <image class="shaking-img shake-animation" src="/assets/shaking.svg" mode="widthFix"></image>
    <text class="shaking-text active">解析中...</text>
  </view>

  <!-- 按钮 -->
  <button class="cast-btn" bindtap="castHexagram" disabled="{{isAnimating || showShakeHint || isShaking}}">摇一卦</button>

  <!-- 副标题 -->
  <view class="mid-subtitle">
    <text class="subtitle">默念所想↑心诚则灵</text>
  </view>

  <button class="query-btn" bindtap="navigateToQuery" disabled="{{isShakingOrListening}}">手动查询</button>

  <!-- 免责声明 -->
  <view class="disclaimer-btn" bindtap="showDisclaimer">
    <text class="disclaimer-text">⚠️ 免责声明</text>
  </view>

  <!-- 结果 -->
  <view class="result" wx:if="{{hexagram}}">
    <shared-result
      hexagram="{{hexagram}}"
      fortuneAnalysis="{{fortuneAnalysis}}"
      mainFortune="{{mainFortune}}"
      hasShared="{{hasShared}}"
      currentTab="{{currentTab}}"
      bind:tabchange="onTabChange"
      bind:unlock="handleWaitUnlock"
    />
  </view>
</view>

<!-- 免责声明弹窗 -->
<view class="disclaimer-modal" wx:if="{{showDisclaimerModal}}">
  <view class="disclaimer-content">
    <text class="disclaimer-title">免责声明</text>
    <text class="disclaimer-body-text">本小程序为传统文化学习工具，内容仅供参考，不构成任何决策建议。</text>
    <text class="disclaimer-body-text">易经是中华优秀传统文化，请以学习和探索的心态使用。如遇重大决策，请理性思考，咨询专业人士。</text>
    <text class="disclaimer-body-text">本小程序不承担任何因使用本服务而产生的后果。</text>
    <button class="disclaimer-close-btn" bindtap="hideDisclaimer">我已知晓</button>
  </view>
</view>
