<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5DC"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar for menu -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#8B4513"
            app:title="大仙周易"
            app:titleTextColor="#FFFFFF"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
            app:menu="@menu/main" />

        <!-- 标题区域 -->
        <LinearLayout
            android:id="@+id/layoutTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="大仙周易"
                android:textColor="#8B4513"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="默念所想之事，心诚则灵"
                android:textColor="#666"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- 摇卦动画区域 -->
        <FrameLayout
            android:id="@+id/layoutShaking"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="24dp">

            <ImageView
                android:id="@+id/ivShaking"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_shaking"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ivStickOut"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_stick_out"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvShaking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="摇卦中..."
            android:textColor="#8B4513"
            android:textSize="24sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- 算卦按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCastHexagram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="32dp"
            android:backgroundTint="#8B4513"
            android:padding="16dp"
            android:text="算一卦"
            android:textSize="20sp"
            app:cornerRadius="8dp" />

        <!-- 结果区域 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 卦序和卦名 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvHexagramNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="第1卦"
                        android:textColor="#8B4513"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHexagramName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="乾"
                        android:textColor="#8B4513"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSelectedLineName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="·初爻"
                        android:textColor="#FF6B6B"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- 上下卦显示 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="上卦"
                        android:textColor="#666"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvUpperTrigram"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="☰ 乾（天）"
                        android:textColor="#333"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="下卦"
                        android:textColor="#666"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvLowerTrigram"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="☰ 乾（天）"
                        android:textColor="#333"
                        android:textSize="24sp" />

                </LinearLayout>

                <!-- 整体卦象含义 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="卦象含义"
                    android:textColor="#666"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvOverallMeaning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="乾为天，象征刚健、进取、领导、创造。"
                    android:textColor="#333"
                    android:textSize="16sp" />

                <!-- 选项页标签 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tabFortune"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="运势详解"
                        android:textColor="#8B4513"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="#FFECB3" />

                    <TextView
                        android:id="@+id/tabSelected"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="选中爻"
                        android:textColor="#666"
                        android:textSize="14sp"
                        android:background="#F5F5DC" />

                    <TextView
                        android:id="@+id/tabLines"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="其他爻"
                        android:textColor="#666"
                        android:textSize="14sp"
                        android:background="#F5F5DC" />

                </LinearLayout>

                <!-- 六爻详解页面 -->
                <LinearLayout
                    android:id="@+id/pageLines"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:id="@+id/layoutLines"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

                <!-- 选中爻页面 -->
                <LinearLayout
                    android:id="@+id/pageSelected"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvSelectedLine"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_line_card"
                        android:lineSpacingExtra="4dp"
                        android:padding="16dp"
                        android:textColor="#5D4037"
                        android:textSize="15sp" />

                </LinearLayout>

                <!-- 运势解读页面 -->
                <LinearLayout
                    android:id="@+id/pageFortune"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:visibility="gone">

                    <!-- 爱情运势 -->
                    <LinearLayout
                        android:id="@+id/cardLove"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_fortune_item"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvLoveTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="💕 爱情运势 ▶"
                            android:textColor="#E91E63"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvLoveContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textSize="13sp"
                            android:textColor="#333"
                            android:visibility="visible" />
                    </LinearLayout>

                    <!-- 事业运势 -->
                    <LinearLayout
                        android:id="@+id/cardCareer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_fortune_item"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvCareerTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="💼 事业运势 ▶"
                            android:textColor="#2196F3"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCareerContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textSize="13sp"
                            android:textColor="#333"
                            android:visibility="visible" />
                    </LinearLayout>

                    <!-- 财运运势 -->
                    <LinearLayout
                        android:id="@+id/cardWealth"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_fortune_item"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvWealthTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="💰 财运运势 ▶"
                            android:textColor="#FF9800"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvWealthContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textSize="13sp"
                            android:textColor="#333"
                            android:visibility="visible" />
                    </LinearLayout>

                    <!-- 健康运势 -->
                    <LinearLayout
                        android:id="@+id/cardHealth"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_fortune_item"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvHealthTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🏃 健康运势 ▶"
                            android:textColor="#4CAF50"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvHealthContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textSize="13sp"
                            android:textColor="#333"
                            android:visibility="visible" />
                    </LinearLayout>

                    <!-- 家庭运势 -->
                    <LinearLayout
                        android:id="@+id/cardFamily"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_fortune_item"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvFamilyTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🏠 家庭运势 ▶"
                            android:textColor="#9C27B0"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvFamilyContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textSize="13sp"
                            android:textColor="#333"
                            android:visibility="visible" />
                    </LinearLayout>

                    <!-- 人际关系 -->
                    <LinearLayout
                        android:id="@+id/cardRelation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_fortune_item"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvRelationTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🤝 人际关系 ▶"
                            android:textColor="#00BCD4"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvRelationContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textSize="13sp"
                            android:textColor="#333"
                            android:visibility="visible" />
                    </LinearLayout>

                    <!-- 投资理财 -->
                    <LinearLayout
                        android:id="@+id/cardStock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_fortune_item"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvStockTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="📊 投资理财 ▶"
                            android:textColor="#795548"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvStockContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textSize="13sp"
                            android:textColor="#333"
                            android:visibility="visible" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
