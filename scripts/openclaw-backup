#!/bin/bash
# OpenClaw 一键备份/恢复命令

# 颜色输出
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

show_help() {
    cat << EOF
OpenClaw 配置备份/恢复工具

用法:
  openclaw-backup <command> [options]

命令:
  backup                    备份当前配置到本地
  backup-push              备份并推送到 GitHub
  restore <repo-url>       从 GitHub 恢复配置
  status                   查看备份状态

示例:
  # 本地备份
  openclaw-backup backup

  # 备份并推送到 GitHub
  openclaw-backup backup-push

  # 从 GitHub 恢复
  openclaw-backup restore https://github.com/username/openclaw-backup.git

  # 使用简短格式
  openclaw-backup restore github:username/openclaw-backup

  # 查看状态
  openclaw-backup status

配置:
  - 备份目录: /tmp/openclaw-backup
  - GitHub 仓库名: openclaw-backup

更多信息:
  https://github.com/username/openclaw-backup

EOF
}

backup_config() {
    echo -e "${GREEN}开始备份配置...${NC}"
    bash /workspace/projects/scripts/backup_config.sh
}

backup_and_push() {
    echo -e "${GREEN}开始备份并推送到 GitHub...${NC}"

    # 先执行备份
    backup_config

    # 推送到 GitHub
    BACKUP_DIR="/tmp/openclaw-backup"
    cd "$BACKUP_DIR"

    # 检查是否已配置远程仓库
    if git remote get-url origin >/dev/null 2>&1; then
        echo -e "${YELLOW}已配置远程仓库，正在推送...${NC}"
        git push origin main 2>/dev/null || git push origin master 2>/dev/null
        echo -e "${GREEN}推送完成！${NC}"
    else
        echo -e "${YELLOW}未配置远程仓库${NC}"
        echo -e "\n${GREEN}请选择以下方式之一：${NC}"

        echo -e "\n方式1: 使用 GitHub CLI 自动创建"
        echo -e "  gh repo create openclaw-backup --public --source=. --remote=origin --push"

        echo -e "\n方式2: 手动创建仓库"
        echo -e "  1. 访问 https://github.com/new"
        echo -e "  2. 创建新仓库: openclaw-backup"
        echo -e "  3. 执行以下命令:"
        echo -e "     git remote add origin https://github.com/YOUR_USERNAME/openclaw-backup.git"
        echo -e "     git branch -M main"
        echo -e "     git push -u origin main"

        echo -e "\n方式3: 修改脚本中的 GITHUB_REPO 变量"
        echo -e "  编辑: /workspace/projects/scripts/backup_config.sh"
        echo -e "  修改: GITHUB_REPO=\"你的仓库名\""
    fi
}

restore_config() {
    if [ -z "$1" ]; then
        echo -e "${YELLOW}错误: 请指定仓库地址${NC}"
        echo -e "\n用法: openclaw-backup restore <repo-url>"
        echo -e "示例: openclaw-backup restore https://github.com/username/openclaw-backup.git"
        exit 1
    fi

    # 处理简短格式
    REPO_URL="$1"
    if [[ "$REPO_URL" == github:* ]]; then
        REPO_PATH="${REPO_URL#github:}"
        REPO_URL="https://github.com/${REPO_PATH}.git"
    fi

    echo -e "${GREEN}从以下地址恢复配置:${NC}"
    echo -e "  $REPO_URL"
    echo -e "\n${YELLOW}这将覆盖当前配置！${NC}"
    echo -n "确认继续？(yes/no): "
    read confirm

    if [ "$confirm" != "yes" ]; then
        echo -e "${YELLOW}已取消${NC}"
        exit 0
    fi

    bash /workspace/projects/scripts/restore_config.sh "$REPO_URL"
}

show_status() {
    BACKUP_DIR="/tmp/openclaw-backup"
    WORKSPACE="/workspace/projects/workspace"

    echo -e "${GREEN}========================================${NC}"
    echo -e "${GREEN}OpenClaw 配置状态${NC}"
    echo -e "${GREEN}========================================${NC}"

    echo -e "\n${YELLOW}工作区文件:${NC}"
    for file in SOUL.md MEMORY.md AGENTS.md TOOLS.md; do
        if [ -f "$WORKSPACE/$file" ]; then
            size=$(du -h "$WORKSPACE/$file" | cut -f1)
            mtime=$(stat -c %y "$WORKSPACE/$file" | cut -d' ' -f1-2)
            echo -e "  ✓ $file ($size, $mtime)"
        else
            echo -e "  ✗ $file (不存在)"
        fi
    done

    echo -e "\n${YELLOW}备份状态:${NC}"
    if [ -d "$BACKUP_DIR" ]; then
        backup_size=$(du -sh "$BACKUP_DIR" | cut -f1)
        backup_time=$(stat -c %y "$BACKUP_DIR" | cut -d' ' -f1-2)
        echo -e "  ✓ 备份存在 ($backup_size, $backup_time)"
    else
        echo -e "  ✗ 备份不存在"
    fi

    if [ -d "$BACKUP_DIR" ] && [ -d "$BACKUP_DIR/.git" ]; then
        cd "$BACKUP_DIR"
        if git remote get-url origin >/dev/null 2>&1; then
            remote_url=$(git remote get-url origin)
            echo -e "  ✓ 远程仓库: $remote_url"
        else
            echo -e "  ✗ 未配置远程仓库"
        fi
    fi

    echo -e "\n${YELLOW}脚本文件:${NC}"
    for script in backup_config.sh restore_config.sh; do
        if [ -f "/workspace/projects/scripts/$script" ]; then
            echo -e "  ✓ $script"
        else
            echo -e "  ✗ $script"
        fi
    done

    echo -e "\n${GREEN}========================================${NC}"
}

# 主逻辑
case "$1" in
    backup)
        backup_config
        ;;
    backup-push)
        backup_and_push
        ;;
    restore)
        restore_config "$2"
        ;;
    status)
        show_status
        ;;
    help|--help|-h|"")
        show_help
        ;;
    *)
        echo -e "${YELLOW}未知命令: $1${NC}"
        echo -e "\n使用 'openclaw-backup help' 查看帮助"
        exit 1
        ;;
esac
